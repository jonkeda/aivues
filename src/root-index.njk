<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AiVues — Smart Glasses Guide</title>
  <meta name="description" content="Smart glasses guide for visually impaired people — available in English and Dutch">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="alternate" hreflang="en" href="{{ site.url }}/en/">
  <link rel="alternate" hreflang="nl" href="{{ site.url }}/nl/">
  <link rel="alternate" hreflang="x-default" href="{{ site.url }}/">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: #ffffff;
      color: #1a1a2e;
      padding: 2rem;
      text-align: center;
    }
    @media (prefers-color-scheme: dark) {
      body { background: #1a1a2e; color: #f0f0f0; }
      a { color: #6db3f2; }
      a:hover { color: #a3d4ff; }
    }
    h1 { font-size: 2rem; margin-bottom: 0.5rem; }
    p { font-size: 1.125rem; margin-bottom: 2rem; color: inherit; opacity: 0.8; }
    .lang-links { list-style: none; display: flex; gap: 1rem; }
    .lang-links a {
      display: block;
      padding: 1rem 2.5rem;
      background: #0056b3;
      color: #fff;
      text-decoration: none;
      border-radius: 4px;
      font-weight: bold;
      font-size: 1.25rem;
      min-height: 44px;
      min-width: 44px;
    }
    .lang-links a:hover { background: #003d80; }
    @media (prefers-color-scheme: dark) {
      .lang-links a { background: #6db3f2; color: #1a1a2e; }
      .lang-links a:hover { background: #a3d4ff; }
    }
  </style>
</head>
<body>
  <h1>AiVues</h1>
  <p>Smart glasses guide for visually impaired people</p>
  <ul class="lang-links" role="list">
    <li><a href="/en/" lang="en" id="link-en">English</a></li>
    <li><a href="/nl/" lang="nl" id="link-nl">Nederlands</a></li>
  </ul>
  <script>
    (function () {
      // Auto-redirect first-time visitors based on browser language
      if (localStorage.getItem('lang-chosen')) return;
      var lang = (navigator.language || '').toLowerCase();
      if (lang === 'nl' || lang.startsWith('nl-')) {
        localStorage.setItem('lang-chosen', 'nl');
        window.location.replace('/nl/');
      } else {
        localStorage.setItem('lang-chosen', 'en');
        window.location.replace('/en/');
      }
    })();
  </script>
</body>
</html>
