<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — AiVues</title>
  <meta name="description" content="{{ description | default(site.tagline[lang]) }}">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <meta property="og:title" content="{{ title }} — AiVues">
  <meta property="og:description" content="{{ description | default(site.tagline[lang]) }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:locale" content="{% if lang == 'nl' %}nl_NL{% else %}en_US{% endif %}">
  <meta property="og:site_name" content="AiVues">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{{ title }} — AiVues">
  <meta name="twitter:description" content="{{ description | default(site.tagline[lang]) }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  {%- set otherUrl = page.url | translationUrl(navigation, lang) %}
  <link rel="alternate" hreflang="{% if lang == 'en' %}en{% else %}nl{% endif %}" href="{{ site.url }}{{ page.url }}">
  <link rel="alternate" hreflang="{% if lang == 'en' %}nl{% else %}en{% endif %}" href="{{ site.url }}{{ otherUrl }}">
  <link rel="stylesheet" href="/css/style.css">
  <script defer src="/js/main.js"></script>
</head>
<body>
  <a class="skip-link" href="#main">
    {%- if lang == "nl" %}Ga naar inhoud{% else %}Skip to main content{% endif -%}
  </a>

  <header class="site-header">
    <nav aria-label="{% if lang == 'nl' %}Hoofdnavigatie{% else %}Main navigation{% endif %}">
      <span class="site-name"><a href="/{{ lang }}/">AiVues</a></span>
      <button class="nav-toggle" aria-expanded="false" aria-label="{% if lang == 'nl' %}Menu openen{% else %}Open menu{% endif %}" type="button">
        <span aria-hidden="true">☰</span>
      </button>
      <ul class="nav-links" role="list">
        {%- for item in navigation.items %}
        <li>
          <a href="{{ item['url_' + lang] }}"
             {%- if page.url == item['url_' + lang] %} aria-current="page"{% endif %}>
            {{ item[lang] }}
          </a>
        </li>
        {%- endfor %}
      </ul>
    </nav>
    <div class="controls">
      <div class="selector phone-selector" role="group" aria-label="{% if lang == 'nl' %}Telefoontype{% else %}Phone type{% endif %}">
        <button class="selector-btn" data-phone="iphone" type="button">iPhone</button>
        <button class="selector-btn" data-phone="android" type="button">Android</button>
      </div>
      <div class="selector lang-selector" role="group" aria-label="{% if lang == 'nl' %}Taal{% else %}Language{% endif %}">
        {%- set otherLangUrl = page.url | translationUrl(navigation, lang) %}
        {%- if lang == "en" %}
        <a href="{{ page.url }}" class="selector-btn is-active">English</a>
        <a href="{{ otherLangUrl }}" class="selector-btn" lang="nl">Nederlands</a>
        {%- else %}
        <a href="{{ otherLangUrl }}" class="selector-btn" lang="en">English</a>
        <a href="{{ page.url }}" class="selector-btn is-active">Nederlands</a>
        {%- endif %}
      </div>
      <button class="theme-toggle" aria-label="{% if lang == 'nl' %}Wissel thema{% else %}Toggle dark mode{% endif %}" type="button">
        <span class="theme-icon" aria-hidden="true">☀️</span>
      </button>
    </div>
  </header>

  <div class="page-layout{% if sidebar %} has-sidebar{% endif %}">
    <main id="main">
      {{ content | safe }}
    </main>

    {%- if sidebar %}
    <nav aria-label="{% if lang == 'nl' %}Op deze pagina{% else %}On this page{% endif %}" class="page-index">
      <h2>{% if lang == "nl" %}Op deze pagina{% else %}On this page{% endif %}</h2>
      <ul role="list">
        {%- for item in sidebar %}
        <li><a href="#{{ item.id }}">{{ item.label }}</a></li>
        {%- endfor %}
      </ul>
    </nav>
    {%- endif %}
  </div>

  <footer class="site-footer">
    <p>
      <a href="/{{ lang }}/">AiVues</a> ·
      {% if lang == "nl" %}
        Code: <a href="https://opensource.org/licenses/MIT">MIT</a> ·
        Inhoud: <a href="https://creativecommons.org/licenses/by-sa/4.0/">CC BY-SA 4.0</a>
      {% else %}
        Code: <a href="https://opensource.org/licenses/MIT">MIT</a> ·
        Content: <a href="https://creativecommons.org/licenses/by-sa/4.0/">CC BY-SA 4.0</a>
      {% endif %}
    </p>
  </footer>
</body>
</html>
